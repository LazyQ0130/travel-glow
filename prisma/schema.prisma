generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String?   @unique
  nickname     String
  email        String?   @unique
  phone        String?   @unique
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  passwordHash String
  avatar       String?
  bio          String?
  level        Int       @default(1)
  exp          Int       @default(0)
  failedLoginCount Int   @default(0)
  lastFailedLoginAt DateTime?
  lockedUntil  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  checkins     Checkin[]
  photos       Photo[]
  settings     UserSettings?
  sessions     LoginSession[]
  verificationCodes VerificationCode[]
  emailVerificationCodes EmailVerificationCode[]

  @@index([deletedAt])
}

model VerificationCode {
  id         String    @id @default(cuid())
  userId     String?
  phone      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  ipAddress  String?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, purpose])
  @@index([phone, purpose, consumedAt])
  @@index([userId])
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  userId     String?
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  ipAddress  String?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([email, purpose, consumedAt])
  @@index([userId])
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  privacyVisibility   String   @default("private")
  mapTheme            String   @default("cyber")
  glowColor           String   @default("cyan")
  defaultHomeTab      String   @default("home")
  photoViewMode       String   @default("timeline")
  language            String   @default("zh-CN")
  distanceUnit        String   @default("metric")
  notificationEnabled Boolean  @default(true)
  checkinReminder     Boolean  @default(false)
  yearlyReport        Boolean  @default(true)
  localCacheLabel     String   @default("本地缓存")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginSession {
  id           String   @id @default(cuid())
  userId       String
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Region {
  id          String    @id
  name        String
  shortName   String?
  type        String
  parentId    String?
  code        String?
  regionType  String?
  totalCities Int?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parent      Region?   @relation("RegionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Region[]  @relation("RegionTree")
  checkins    Checkin[]

  @@index([parentId])
  @@index([type])
}

model Checkin {
  id          String   @id @default(cuid())
  userId      String
  regionId    String
  checkinDate DateTime
  note        String?
  title       String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  region      Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  photos      Photo[]

  @@index([userId])
  @@index([regionId])
  @@index([userId, deletedAt, checkinDate])
  @@index([regionId, deletedAt])
}

model Photo {
  id           String   @id @default(cuid())
  userId       String
  checkinId    String
  imageUrl     String
  originalName String?
  mimeType     String?
  size         Int?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkin      Checkin  @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([checkinId])
  @@index([userId, deletedAt, createdAt])
  @@index([checkinId, deletedAt])
}
