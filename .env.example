# App
NODE_ENV=development
PORT=3000
APP_URL="http://localhost:3000"

# Database
# Current Prisma schema uses SQLite. For PostgreSQL production rollout, switch
# prisma/schema.prisma datasource provider to "postgresql" and regenerate
# migrations before using the PostgreSQL URL below as DATABASE_URL.
DATABASE_URL="file:./dev.db"
POSTGRES_DATABASE_URL="postgresql://travel_glow:replace-with-strong-password@localhost:5432/travel_glow?schema=public"

# Auth and security
JWT_SECRET="change-this-secret-before-production"
JWT_EXPIRES_IN="30d"
CORS_ORIGINS="http://localhost:3000"
TRUST_PROXY=false

# SMS: aliyun | tencent | mock
SMS_PROVIDER="mock"
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_TEMPLATE_PARAM_NAME=code
SMS_TIMEOUT_MS=5000

# Tencent Cloud SMS only
SMS_APP_ID=
SMS_REGION=ap-guangzhou
SMS_DEFAULT_COUNTRY_CODE=+86

# Optional endpoint overrides for private network or tests
SMS_ALIYUN_ENDPOINT="https://dysmsapi.aliyuncs.com/"
SMS_TENCENT_ENDPOINT="https://sms.tencentcloudapi.com/"

# Logging and operations
LOG_LEVEL="debug"
BACKUP_DIR=./backups
RUN_MIGRATIONS_ON_START=true
SENTRY_DSN=
