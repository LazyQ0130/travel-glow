# App
NODE_ENV=development
PORT=3000
APP_URL="http://localhost:3000"

# Database
# Current Prisma schema uses SQLite. For PostgreSQL production rollout, switch
# prisma/schema.prisma datasource provider to "postgresql" and regenerate
# migrations before using the PostgreSQL URL below as DATABASE_URL.
DATABASE_URL="file:./dev.db"
POSTGRES_DATABASE_URL="postgresql://travel_glow:replace-with-strong-password@localhost:5432/travel_glow?schema=public"

# Auth and security
JWT_SECRET="change-this-secret-before-production"
JWT_EXPIRES_IN="30d"
CORS_ORIGINS="http://localhost:3000"
TRUST_PROXY=false

# Redis-backed API rate limiting. If Redis is unavailable, the server falls
# back to an in-memory limiter so requests can continue.
RATE_LIMIT_REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=4
REDIS_CONNECT_TIMEOUT_MS=1000
REDIS_COMMAND_TIMEOUT_MS=500
REDIS_FAILURE_COOLDOWN_MS=30000

# Email verification: use smtp for real email delivery.
# For local-only debugging without email delivery, set EMAIL_PROVIDER="mock"
# and EXPOSE_DEV_EMAIL_CODE=true. Do not enable EXPOSE_DEV_EMAIL_CODE in production.
EMAIL_PROVIDER="smtp"
EXPOSE_DEV_EMAIL_CODE=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-account@example.com
SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_FROM=your-smtp-account@example.com
SMTP_TIMEOUT_MS=10000

# Logging and operations
LOG_LEVEL="debug"
LOG_DIR=./logs
LOG_FILE=app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7
BACKUP_DIR=./backups
RUN_MIGRATIONS_ON_START=true
SENTRY_DSN=
